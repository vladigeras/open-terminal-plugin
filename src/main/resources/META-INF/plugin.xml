<idea-plugin>
    <id>com.vladigeras.open-terminal</id>
    <name>Open Terminal</name>

    <vendor email="vladi6eras@gmail.com" url="https://github.com/vladigeras">Vladislav Gerasimov</vendor>

    <description>
        <![CDATA[
            <h4>Use hotkey for quick open your system terminal.</h4>
            <h4>Plugin adds an action in the Tools settings group.</h4>
        ]]>
    </description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
    </extensions>

    <actions>
        <action
            id="com.vladigeras.openterminal.OpenTerminalAction"
            class="com.vladigeras.openterminal.OpenTerminalAction"
            text="Open Terminal"
            description="Quick open system terminal"
            icon="tool.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt T"/>
        </action>
    </actions>
</idea-plugin>